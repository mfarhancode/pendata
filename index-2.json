text","value":"Output:","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"gD4TmilLNc"}],"key":"iqJr7RF50I"}],"key":"n7iTT8l4J0"},{"type":"image","url":"/pendata/build/scatter_petal-86ac3781e7ccf9a44d355d6bb398a302.png","alt":"Scatter Plot Petal Length vs Petal Width","width":"100%","align":"center","key":"XRcA0mGK5b","urlSource":"scatter_petal.png"},{"type":"comment","value":"\n```python\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\ndf = pd.read_csv(\"IRIS.csv\")\nkolom = 'sepal_length'\n\nprint(\"jumlah data      \", df[kolom].count())\nprint(\"rata-rata        \", df[kolom].mean())\nprint(\"Q1               \", df[kolom].quantile(0.25))\nprint(\"Q2 (median)      \", df[kolom].quantile(0.5))\nprint(\"Q3               \", df[kolom].quantile(0.75))\nprint(\"Standar Deviasi  \", round(df[kolom].std(), 2))\nprint(\"Variansi         \", round(df[kolom].var(), 2))\n```\n\n**Output:**\n```\njumlah data       150\nrata-rata         5.843333333333334\nQ1                5.1\nQ2 (median)       5.8\nQ3                6.4\nStandar Deviasi   0.83  \nVariansi          0.69\n```\n","key":"YBCeLDLjTM"},{"type":"thematicBreak","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"MCnBlqQc9u"},{"type":"heading","depth":2,"position":{"start":{"line":147,"column":1},"end":{"line":147,"column":1}},"children":[{"type":"text","value":"Implementasi Orange Data Mining","position":{"start":{"line":147,"column":1},"end":{"line":147,"column":1}},"key":"BWSAPFed0v"}],"identifier":"implementasi-orange-data-mining","label":"Implementasi Orange Data Mining","html_id":"implementasi-orange-data-mining","implicit":true,"key":"jtwD3xTAjA"},{"type":"heading","depth":3,"position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"children":[{"type":"text","value":"Screenshot Workflow","position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"key":"I0b4qkHDnd"}],"identifier":"screenshot-workflow","label":"Screenshot Workflow","html_id":"screenshot-workflow","implicit":true,"key":"oCvejl9nGP"},{"type":"image","url":"/pendata/build/screenshot_orange-dcf0ae99b928077947a7f3cb8b3660d0.png","alt":"Workflow Orange Iris","width":"100%","align":"center","key":"A3iFoHw54C","urlSource":"screenshot_orange.png"},{"type":"comment","value":"\n### Struktur Workflow\n\n1. **CSV File Import → Data Info** — ringkasan 150 baris × 5 kolom\n2. **CSV File Import → Data Table** — tampilkan data mentah\n3. **CSV File Import → Scatter Plot** — hubungan dua atribut numerik\n4. **CSV File Import → Distributions** — distribusi nilai tiap atribut\n5. **CSV File Import → Box Plot** — median, kuartil, dan outlier\n","key":"LdAHa1eMXe"},{"type":"heading","depth":3,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"File Download","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"Ipe1JKQIZd"}],"identifier":"file-download","label":"File Download","html_id":"file-download","implicit":true,"key":"ksA8e0Ym0w"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":166,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/IRIS-f25875ccdb3888750fce4fb5d12282d5.csv","static":true,"children":[{"type":"text","value":"IRIS.csv","key":"Do6NPbVcx0"}],"urlSource":"IRIS.csv","protocol":"file","key":"d6XAanxpCW"}],"key":"m3GKcSkgDw"}],"key":"YyBVBqX3sN"},{"type":"listItem","spread":true,"position":{"start":{"line":167,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/OrangeIrisFlower-5e923b31ab142cb69b3115e4f3aee456.ows","static":true,"children":[{"type":"text","value":"OrangeIrisFlower​.ows","key":"XodLNotlpd"}],"urlSourc