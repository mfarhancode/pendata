enshot-workflow","label":"Screenshot Workflow","html_id":"screenshot-workflow","implicit":true,"key":"JDX51Vc0yP"},{"type":"image","url":"/pendata/build/screenshot_orange-6ac521265f636c7d093ab78ec0533530.png","alt":"Workflow Orange Iris","width":"100%","align":"center","key":"cwX0c3LUKG","urlSource":"screenshot_orange.png"},{"type":"comment","value":"\n### Struktur Workflow\n\n1. **CSV File Import → Data Info** — ringkasan 150 baris × 5 kolom\n2. **CSV File Import → Data Table** — tampilkan data mentah\n3. **CSV File Import → Scatter Plot** — hubungan dua atribut numerik\n4. **CSV File Import → Distributions** — distribusi nilai tiap atribut\n5. **CSV File Import → Box Plot** — median, kuartil, dan outlier\n","key":"TQpIHihDkf"},{"type":"heading","depth":3,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"File Download","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"Zn5SzRJTyi"}],"identifier":"file-download","label":"File Download","html_id":"file-download","implicit":true,"key":"AAu1xpkR8J"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":166,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/IRIS-c6e3db60b37c24aa26edd8ffca51edbc.csv","static":true,"children":[{"type":"text","value":"IRIS.csv","key":"pWtEprzQ9c"}],"urlSource":"IRIS.csv","protocol":"file","key":"wnVdo4Ykbh"}],"key":"tpXAatPb5s"}],"key":"h81NZSLret"},{"type":"listItem","spread":true,"position":{"start":{"line":167,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/OrangeIrisFlower-d86a530cb8e831fbca08eec4ed27fe76.ows","static":true,"children":[{"type":"text","value":"OrangeIrisFlower​.ows","key":"ELDrL8zXPr"}],"urlSourc