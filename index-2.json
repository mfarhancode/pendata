enshot-workflow","label":"Screenshot Workflow","html_id":"screenshot-workflow","implicit":true,"key":"cphgsbrXrM"},{"type":"image","url":"/pendata/build/screenshot_orange-9c93ed625f276d3be247a063eec59a2f.png","alt":"Workflow Orange Iris","width":"100%","align":"center","key":"cINnZG9FfD","urlSource":"screenshot_orange.png"},{"type":"comment","value":"\n### Struktur Workflow\n\n1. **CSV File Import → Data Info** — ringkasan 150 baris × 5 kolom\n2. **CSV File Import → Data Table** — tampilkan data mentah\n3. **CSV File Import → Scatter Plot** — hubungan dua atribut numerik\n4. **CSV File Import → Distributions** — distribusi nilai tiap atribut\n5. **CSV File Import → Box Plot** — median, kuartil, dan outlier\n","key":"XPZpwy59Vy"},{"type":"heading","depth":3,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"File Download","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"d6BoaOe55J"}],"identifier":"file-download","label":"File Download","html_id":"file-download","implicit":true,"key":"rmcU4bYY1v"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":166,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/IRIS-e80ce58f6990c2b17d9cbfabe1092d2c.csv","static":true,"children":[{"type":"text","value":"IRIS.csv","key":"nlnGrGckyi"}],"urlSource":"IRIS.csv","protocol":"file","key":"VvixOSJqU7"}],"key":"XdF0YoapLU"}],"key":"hnQx13WKgs"},{"type":"listItem","spread":true,"position":{"start":{"line":167,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/OrangeIrisFlower-0c9114952edb69448d39dd16c61df1a8.ows","static":true,"children":[{"type":"text","value":"OrangeIrisFlower​.ows","key":"K7lExNYCiv"}],"urlSourc