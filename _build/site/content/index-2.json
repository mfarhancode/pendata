ambut, pekerjaan |\n| **Biner** | Hanya 2 nilai (0/1) | Merokok (ya/tidak) |\n| **Ordinal** | Ada urutan, tapi jarak tidak diketahui | Kecil/Sedang/Besar |\n| **Numerik** | Kuantitatif, terukur | Suhu, berat badan |\n\n---\n","key":"cMJFe8TbKO"},{"type":"heading","depth":2,"position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"Implementasi","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"lypXhVo4dk"}],"identifier":"implementasi","label":"Implementasi","html_id":"implementasi","implicit":true,"key":"We6L3uOQme"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"link","url":"https://colab.research.google.com/drive/1KIBnoRXwLjL98FPCg7OfFNyJhjZmgLU2?usp=sharing","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Buka di Google Colab","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"RXCT5n426F"}],"urlSource":"https://colab.research.google.com/drive/1KIBnoRXwLjL98FPCg7OfFNyJhjZmgLU2?usp=sharing","key":"IqaRUGuPxN"}],"key":"RRCSJakAGV"},{"type":"heading","depth":3,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Kode Program — Dataset IRIS","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"EFDcAFGN69"}],"identifier":"kode-program-dataset-iris","label":"Kode Program — Dataset IRIS","html_id":"kode-program-dataset-iris","implicit":true,"key":"IYdws3v7Gj"},{"type":"heading","depth":2,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Descriptive Statistics","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"iC0uJMgwaA"}],"identifier":"descriptive-statistics","label":"Descriptive Statistics","html_id":"descriptive-statistics","implicit":true,"key":"tYsMF1sSKV"},{"type"