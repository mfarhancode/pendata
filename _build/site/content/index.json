{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"strong","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Main Reference:","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"kVJ8ak6hfD"}],"key":"mFSPlVdflY"},{"type":"text","value":" ","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"h4sgrfC6zS"},{"type":"link","url":"https://mulaab.github.io/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"https://​mulaab​.github​.io​/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"ueJKcXQT8C"}],"urlSource":"https://mulaab.github.io/datamining/","key":"iPAWPvRuF3"}],"key":"ViOPuWf8rY"},{"type":"thematicBreak","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"bPzgOzpNb1"},{"type":"comment","value":" \n## What Will You Learn?\n\n1. **Pengantar Data Mining** — Konsep dasar, CRISP-DM, tugas utama data mining\n2. **Memahami Data** — Tipe atribut: nominal, biner, ordinal, numerik\n3. **Pengantar Data Science** — Hubungan data mining dengan data science\n4. **Distribusi & Statistik Deskriptif** — Mean, median, modus, variansi, boxplot\n5. **Mengukur Jarak/Similaritas** — Euclidean, Manhattan, Cosine, Jaccard, dll\n6. **Praproses Data** — Pembersihan, seleksi atribut, transformasi data\n7. **Modeling** — Membangun model klasifikasi, clustering, dll\n8. **Evaluasi Model** — Mengevaluasi performa model data mining\n","key":"xMIttGPuGV"},{"type":"thematicBreak","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"fOC3WEl0u2"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Meeting List","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"gyDBqXtbM8"}],"identifier":