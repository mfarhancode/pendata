":"python","value":"import pandas as pd\nfrom scipy import stats\n\ndf = pd.read_csv(\"IRIS.csv\")\nprint(\"Shape dataset:\", df.shape)\n\nkolom = 'sepal_length'\n\nprint(\"jumlah data      \", df[kolom].count())\nprint(\"rata-rata        \", df[kolom].mean())\nprint(\"nilai minimal    \", df[kolom].min())\nprint(\"Q1               \", df[kolom].quantile(0.25))\nprint(\"Q2 (median)      \", df[kolom].quantile(0.5))\nprint(\"Q3               \", df[kolom].quantile(0.75))\nprint(\"Nilai Max        \", df[kolom].max())\nprint(\"kemencengan      \", \"{0:.2f}\".format(round(df[kolom].skew(), 2)))\n\nmodus = df[kolom].mode()\nif len(modus) > 0:\n    nilai_modus = modus.iloc[0]\n    jumlah_modus = (df[kolom] == nilai_modus).sum()\n    print(\"Nilai modus {} dengan jumlah {}\".format(nilai_modus, jumlah_modus))\n\nprint(\"Standar Deviasi  \", \"{0:.2f}\".format(round(df[kolom].std(), 2)))\nprint(\"Variansi         \", \"{0:.2f}\".format(round(df[kolom].var(), 2)))","position":{"start":{"line":67,"column":1},"end":{"line":93,"column":1}},"key":"lV8N224chZ"},{"type":"paragraph","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"strong","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"Output:","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"zsL8ClWoB0"}],"key":"xrY5BxgViK"}],"key":"oMYgnwEwy3"},{"type":"code","lang":"","value":"Shape dataset: (150, 5)\njumlah data       150\nrata-rata         5.843333333333334\nnilai minimal     4.3\nQ1                5.1\nQ2 (median)       5.8\nQ3                6.4\nNilai Max         7.9\nkemencengan       0.31\nNilai modus 5.0 dengan jumlah 10\nStandar Deviasi   0.83\nVariansi          0.69","position":{"start":{"line":97,"column":1},"end":{"line":110,"column":1}},"key":"nBAJReEIHR"},{"type":"thematicBreak","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"scxuZV3Buv"},{"type