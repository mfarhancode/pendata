:{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"DFi8Rw04Gu"}],"key":"TdV4tHia7l"},{"type":"text","value":" ","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"SYYCJmugEs"},{"type":"link","url":"https://mulaab.github.io/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"https://​mulaab​.github​.io​/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"AqnGJwld4C"}],"urlSource":"https://mulaab.github.io/datamining/","key":"Ry6DmeC6ic"}],"key":"Tj8b58R90a"},{"type":"thematicBreak","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"XjrFrvA7y3"},{"type":"comment","value":" \n## What Will You Learn?\n\n1. **Pengantar Data Mining** — Konsep dasar, CRISP-DM, tugas utama data mining\n2. **Memahami Data** — Tipe atribut: nominal, biner, ordinal, numerik\n3. **Pengantar Data Science** — Hubungan data mining dengan data science\n4. **Distribusi & Statistik Deskriptif** — Mean, median, modus, variansi, boxplot\n5. **Mengukur Jarak/Similaritas** — Euclidean, Manhattan, Cosine, Jaccard, dll\n6. **Praproses Data** — Pembersihan, seleksi atribut, transformasi data\n7. **Modeling** — Membangun model klasifikasi, clustering, dll\n8. **Evaluasi Model** — Mengevaluasi performa model data mining\n","key":"f7ZDdeXVyK"},{"type":"thematicBreak","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"jNdqXdoE68"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Meeting List","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"jcQbYLWxxh"}],"identifier":"meeting-list","label":"Meeting List","html_id":"meeting-list","implicit":true,"key":"DP91LLgxv3"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":66,"column":1},"end":{"line":68,"column":1}},