:{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"eaTGDMzfsa"}],"key":"qk3Ra7H35r"},{"type":"text","value":" ","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"LbanZqyTCC"},{"type":"link","url":"https://mulaab.github.io/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"https://​mulaab​.github​.io​/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"r8pHhzTezH"}],"urlSource":"https://mulaab.github.io/datamining/","key":"wiqH0uNpwf"}],"key":"oRjIE0dZYF"},{"type":"thematicBreak","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"v6WXTPK8BY"},{"type":"comment","value":" \n## What Will You Learn?\n\n1. **Pengantar Data Mining** — Konsep dasar, CRISP-DM, tugas utama data mining\n2. **Memahami Data** — Tipe atribut: nominal, biner, ordinal, numerik\n3. **Pengantar Data Science** — Hubungan data mining dengan data science\n4. **Distribusi & Statistik Deskriptif** — Mean, median, modus, variansi, boxplot\n5. **Mengukur Jarak/Similaritas** — Euclidean, Manhattan, Cosine, Jaccard, dll\n6. **Praproses Data** — Pembersihan, seleksi atribut, transformasi data\n7. **Modeling** — Membangun model klasifikasi, clustering, dll\n8. **Evaluasi Model** — Mengevaluasi performa model data mining\n","key":"TrHYm9ZqJ4"},{"type":"thematicBreak","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"cDGo2xmpxp"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Meeting List","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"CJnZWbvtZF"}],"identifier":"meeting-list","label":"Meeting List","html_id":"meeting-list","implicit":true,"key":"u359HHng4H"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":66,"column":1},"end":{"line":70,"column":1}},