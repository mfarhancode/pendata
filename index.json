:{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"EIP2LGEs6F"}],"key":"aVV9XpCk9m"},{"type":"text","value":" ","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"ZVY3d4hwwD"},{"type":"link","url":"https://mulaab.github.io/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"https://​mulaab​.github​.io​/datamining/","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"mp7GMvh3D9"}],"urlSource":"https://mulaab.github.io/datamining/","key":"iRswi2PMkH"}],"key":"JxxYoYNaxP"},{"type":"thematicBreak","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"C7jp2cm8ud"},{"type":"comment","value":" \n## What Will You Learn?\n\n1. **Pengantar Data Mining** — Konsep dasar, CRISP-DM, tugas utama data mining\n2. **Memahami Data** — Tipe atribut: nominal, biner, ordinal, numerik\n3. **Pengantar Data Science** — Hubungan data mining dengan data science\n4. **Distribusi & Statistik Deskriptif** — Mean, median, modus, variansi, boxplot\n5. **Mengukur Jarak/Similaritas** — Euclidean, Manhattan, Cosine, Jaccard, dll\n6. **Praproses Data** — Pembersihan, seleksi atribut, transformasi data\n7. **Modeling** — Membangun model klasifikasi, clustering, dll\n8. **Evaluasi Model** — Mengevaluasi performa model data mining\n","key":"lsFTon7q2g"},{"type":"thematicBreak","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"xYpbPqOZr7"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Meeting List","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"oRxrgC3yGN"}],"identifier":"meeting-list","label":"Meeting List","html_id":"meeting-list","implicit":true,"key":"kJVGliWfIt"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":66,"column":1},"end":{"line":69,"column":1}},