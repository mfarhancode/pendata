text","value":"Output:","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"U9K0Oy9ZMi"}],"key":"YAiLndAhec"}],"key":"jnyBsGYe8A"},{"type":"image","url":"/pendata/build/scatter_petal-0b7a53b5e3d9dbaf78aee2b54eb9d419.png","alt":"Scatter Plot Petal Length vs Petal Width","width":"100%","align":"center","key":"iUWT04vzcX","urlSource":"scatter_petal.png"},{"type":"comment","value":"\n```python\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\ndf = pd.read_csv(\"IRIS.csv\")\nkolom = 'sepal_length'\n\nprint(\"jumlah data      \", df[kolom].count())\nprint(\"rata-rata        \", df[kolom].mean())\nprint(\"Q1               \", df[kolom].quantile(0.25))\nprint(\"Q2 (median)      \", df[kolom].quantile(0.5))\nprint(\"Q3               \", df[kolom].quantile(0.75))\nprint(\"Standar Deviasi  \", round(df[kolom].std(), 2))\nprint(\"Variansi         \", round(df[kolom].var(), 2))\n```\n\n**Output:**\n```\njumlah data       150\nrata-rata         5.843333333333334\nQ1                5.1\nQ2 (median)       5.8\nQ3                6.4\nStandar Deviasi   0.83  \nVariansi          0.69\n```\n","key":"jh6yvD6bAS"},{"type":"thematicBreak","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"tD37CEo6zQ"},{"type":"heading","depth":2,"position":{"start":{"line":147,"column":1},"end":{"line":147,"column":1}},"children":[{"type":"text","value":"Implementasi Orange Data Mining","position":{"start":{"line":147,"column":1},"end":{"line":147,"column":1}},"key":"rNYZtL3rrn"}],"identifier":"implementasi-orange-data-mining","label":"Implementasi Orange Data Mining","html_id":"implementasi-orange-data-mining","implicit":true,"key":"OIKhP644Iu"},{"type":"heading","depth":3,"position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"children":[{"type":"text","value":"Screenshot Workflow","position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"key":"GJTPemWNBo"}],"identifier":"screenshot-workflow","label":"Screenshot Workflow","html_id":"screenshot-workflow","implicit":true,"key":"h7aimkcKnn"},{"type":"image","url":"/pendata/build/screenshot_orange-0dd193999fae18dcdc6cc8a5cd1151dc.png","alt":"Workflow Orange Iris","width":"100%","align":"center","key":"cyFQZo0lQH","urlSource":"screenshot_orange.png"},{"type":"comment","value":"\n### Struktur Workflow\n\n1. **CSV File Import → Data Info** — ringkasan 150 baris × 5 kolom\n2. **CSV File Import → Data Table** — tampilkan data mentah\n3. **CSV File Import → Scatter Plot** — hubungan dua atribut numerik\n4. **CSV File Import → Distributions** — distribusi nilai tiap atribut\n5. **CSV File Import → Box Plot** — median, kuartil, dan outlier\n","key":"qhwLzlnpZ4"},{"type":"heading","depth":3,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"File Download","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"WFf3VD70PE"}],"identifier":"file-download","label":"File Download","html_id":"file-download","implicit":true,"key":"mLvWRFFp8f"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":166,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/IRIS-c611d4a284b0dfd2124193120c801ebb.csv","static":true,"children":[{"type":"text","value":"IRIS.csv","key":"UcBAPNell7"}],"urlSource":"IRIS.csv","protocol":"file","key":"gZRVdDcM6E"}],"key":"S1FM4GKVRJ"}],"key":"cBhnUG7yzt"},{"type":"listItem","spread":true,"position":{"start":{"line":167,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/OrangeIrisFlower-12b58a94339ac5ad53125f2a7627ef3d.ows","static":true,"children":[{"type":"text","value":"OrangeIrisFlower​.ows","key":"gQfyhPcAVd"}],"urlSourc