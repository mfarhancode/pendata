timedia\n- **Data Streaming** — data real-time dari ribuan sumber\n\n---\n\n## Tipe Data Atribut\n\n| Tipe | Keterangan | Contoh |\n|---|---|---|\n| **Nominal** | Kategori tanpa urutan | Warna rambut, pekerjaan |\n| **Biner** | Hanya 2 nilai (0/1) | Merokok (ya/tidak) |\n| **Ordinal** | Ada urutan, tapi jarak tidak diketahui | Kecil/Sedang/Besar |\n| **Numerik** | Kuantitatif, terukur | Suhu, berat badan |\n\n---\n","key":"LU8kFNHhk1"},{"type":"heading","depth":2,"position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"Implementasi","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"ycYUTda7Le"}],"identifier":"implementasi","label":"Implementasi","html_id":"implementasi","implicit":true,"key":"qdtLd15gfT"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"link","url":"https://colab.research.google.com/drive/1KIBnoRXwLjL98FPCg7OfFNyJhjZmgLU2?usp=sharing","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Buka di Google Colab","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"ls340Kcftw"}],"urlSource":"https://colab.research.google.com/drive/1KIBnoRXwLjL98FPCg7OfFNyJhjZmgLU2?usp=sharing","key":"WDmKHq89ev"}],"key":"u4IaAAKQjO"},{"type":"heading","depth":3,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Kode Program — Dataset IRIS","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"DuAlxoMfIY"}],"identifier":"kode-program-dataset-iris","label":"Kode Program — Dataset IRIS","html_id":"kode-program-dataset-iris","implicit":true,"key":"cHqjc2ZJlC"},{"type":"heading","depth":2,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Descriptive Statistics","position":{"start":{"line":40,"column":1},"end":