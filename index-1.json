enshot-workflow","label":"Screenshot Workflow","html_id":"screenshot-workflow","implicit":true,"key":"IPp4tOHbY0"},{"type":"image","url":"/pendata/build/screenshot_orange-070e2a0e8cbc4e43608932dacfb3f60f.png","alt":"Workflow Orange Iris","width":"100%","align":"center","key":"XMC5YpGRwq","urlSource":"screenshot_orange.png"},{"type":"comment","value":"\n### Struktur Workflow\n\n1. **CSV File Import → Data Info** — ringkasan 150 baris × 5 kolom\n2. **CSV File Import → Data Table** — tampilkan data mentah\n3. **CSV File Import → Scatter Plot** — hubungan dua atribut numerik\n4. **CSV File Import → Distributions** — distribusi nilai tiap atribut\n5. **CSV File Import → Box Plot** — median, kuartil, dan outlier\n","key":"rizPGPNJLv"},{"type":"heading","depth":3,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"File Download","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"bM8AWpACLP"}],"identifier":"file-download","label":"File Download","html_id":"file-download","implicit":true,"key":"YoGbZGdUpx"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":166,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":166,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/IRIS-8615f4a60a73f8d4594fe6e19a21722d.csv","static":true,"children":[{"type":"text","value":"IRIS.csv","key":"qNtN2cN6zL"}],"urlSource":"IRIS.csv","protocol":"file","key":"Wlbi2BSzF2"}],"key":"qXsT0xaeMF"}],"key":"ze6MG6CqO2"},{"type":"listItem","spread":true,"position":{"start":{"line":167,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"/pendata/build/OrangeIrisFlower-be8813d157a0ea3dba3ec64b611515eb.ows","static":true,"children":[{"type":"text","value":"OrangeIrisFlower​.ows","key":"NNmK1dtI4N"}],"urlSourc