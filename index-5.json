uri":"https://localhost:8080/","height":527},"id":"nG7Q11BKnNMQ","outputId":"8d70db60-cdbd-4d6e-e5fd-c6c4e53f0509"},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom sklearn.linear_model import LinearRegression\n\n# 1. Setup Data\nX = np.array([[2], [4], [3], [3], [3], [4], [5]])\ny = np.array([2, 3, 5, 4, 3, 5, 6])\n\n# 2. Instantiate and Fit Library Model\nmodel = LinearRegression()\nmodel.fit(X, y)\n\n# Print calculations\nprint(f\"Intercept (b0): {model.intercept_:.2f}\")\nprint(f\"Slope Coefficient (b1): {model.coef_[0]:.2f}\")\nprint(f\"Equation: y = {model.intercept_:.2f} + {model.coef_[0]:.2f}x\")\n\n# 3. IMAGE / PLOT FEATURE\n\n# Plot the blue data points\nplt.scatter(X, y, color='blue', label='Data Points', s=80)\n\n# Generate predictions for a smooth line spanning from x=1 to x=6\nx_range = np.linspace(1, 6, 100).reshape(-1, 1)\ny_pred = model.predict(x_range)\n\n# Plot the red regression line\nplt.plot(x_range, y_pred, color='red', label=f'y = {model.intercept_:.2f} + {model.coef_[0]:.2f}x')\n\n# Chart labels and settings\nplt.title(\"Linear Regression Visualization\")\nplt.xlabel(\"X\")\nplt.ylabel(\"Y\")\nplt.grid(True, linestyle='--', alpha=0.5)\nplt.legend()\n\n# Display the image\nplt.show()","identifier":"ng7q11bknnmq-code","enumerator":"1","html_id":"ng7q11bknnmq-code","key":"ExbTmhZRwl"},{"type":"outputs","id":"jIGsLa7mDjOhA2uUAgA6p","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Intercept (b0): 0.40\nSlope Coefficient (b1): 1.05\nEquation: y = 0.40 + 1.05x\n"},"children":[],"identifier":"ng7q11bknnmq-outputs-0","html_id":"ng7q11bknnmq-outputs-0","key":"Rzcp0ABZZG"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"a6a78f2fb1908e05e58e62f6735d1c10","path":"/pendata/build/a6a78f2fb1908e05e58e62f6735d1c10.png"},"text/plain":{"content":"<Figure siz